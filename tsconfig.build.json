{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./", 
    "declaration": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "incremental": false
  },
  "include": ["src/**/*.ts", "prisma/**/*.ts"], 
  "exclude": ["node_modules", "dist", "test", "**/*.spec.ts"]
}